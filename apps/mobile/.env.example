# Lumenpulse Mobile - Environment Variables
# Copy this file to .env and configure as needed.

# API Base URL for backend integration
# Use EXPO_PUBLIC_ prefix to make it available in the app
EXPO_PUBLIC_API_URL=http://localhost:3000

# Expo Project Configuration
EXPO_PUBLIC_APP_VARIANT=development

# Stellar / Soroban Configuration
EXPO_PUBLIC_STELLAR_NETWORK=testnet
EXPO_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
EXPO_PUBLIC_CROWDFUND_CONTRACT_ID=
EXPO_PUBLIC_STELLAR_EXPLORER_URL=https://stellar.expert/explorer
